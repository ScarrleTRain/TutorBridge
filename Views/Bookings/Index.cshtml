@model IEnumerable<TutorBridge.Models.Booking>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.UserId)
            </th>
            <th>
                <span>Tutor</span>
            </th>
            <th>
                <span>Time</span>
            </th>
            <th>
                <span>Subject</span>
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr class="@(item.Status switch
            {
                Booking.BookingStatus.Pending => "bg-warning bg-opacity-25",
                Booking.BookingStatus.Confirmed => "bg-success bg-opacity-25",
                Booking.BookingStatus.Cancelled => "bg-danger bg-opacity-25",
                _ => ""
            })" style="--bs-table-bg: transparent;">
            <td>
                @item.User.NameFirst @item.User.NameLast
            </td>
            <td>
                @item.TimeSlot.Tutor.NameFirst @item.TimeSlot.Tutor.NameLast
            </td>
            <td>
                @item.TimeSlot.DateTimeStart.ToString("dd/MM/yyyy")
                @item.TimeSlot.DateTimeStart.ToString("h:mm tt") -
                @item.TimeSlot.DateTimeEnd.ToString("h:mm tt")
            </td>
            <td>
                @item.Subject.Name
            </td>
            <td>
                @item.Status
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
