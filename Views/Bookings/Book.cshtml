@model TutorBridge.Models.Booking
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject IWebHostEnvironment Env

@{
    ViewData["Title"] = "Book";

    string? photoPath = ViewBag.Tutor.ProfilePhoto != null
        ? System.IO.Path.Combine(Env.WebRootPath, "images", "tutors", ViewBag.Tutor.ProfilePhoto)
        : null;
    bool photoExists = photoPath != null && System.IO.File.Exists(photoPath);
}

@* <script>
    console.log("Claims:");
    @foreach (var claim in User.Claims)
    {
        @:console.log("@claim.Type : @claim.Value");
    }
</script> *@

<h1>Book@* - @ViewBag.Tutor.NameFirst @ViewBag.Tutor.NameLast*@</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">          
            <div class="card flex-shrink-0 m-2" style="width: 18rem;">
                <img class="card-img-top" src="~/images/tutors/@(photoExists ? ViewBag.Tutor.ProfilePhoto : "default.jpg")" alt="@ViewBag.Tutor.NameFirst @ViewBag.Tutor.NameLast">
                <div class="card-body">
                    <h5 class="card-title">@ViewBag.Tutor.NameFirst @ViewBag.Tutor.NameLast</h5>
                    <p class="card-text">@ViewBag.Tutor.Blurb</p>
                </div>
            </div>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TimeSlotId" class="control-label">Timeslot</label>
                <select asp-for="TimeSlotId" asp-items="ViewBag.TimeSlots" class="form-control">
                    <option value="">-- Select a time --</option>
                </select>
                <span asp-validation-for="TimeSlotId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SubjectId" class="control-label">Subject</label>
                <select asp-for="SubjectId" asp-items="ViewBag.Subjects" class="form-control">
                    <option value="">-- Select a subject --</option>
                </select>
                <span asp-validation-for="SubjectId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
